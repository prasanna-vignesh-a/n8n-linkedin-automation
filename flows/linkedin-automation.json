    {
      "parameters": {
        "jsCode": "const rawOutput = $json.output;\n\nconst cleaned = rawOutput\n  .replace(/\\*\\*(.*?)\\*\\*/g, '🔹 $1')   // Replace **bold** with 🔹 text\n  .replace(/\\n/g, \"\\\\n\")               // Escape newlines\n  .replace(/\"/g, '\\\\\"');               // Escape double quotes\n\nreturn [\n  {\n    json: {\n      cleanOutput: cleaned\n    }\n  }\n];\n\n"
      },
